exports[`ProfileStatCard (vue) > affiche une armure portée (Brigandine) en plus de l'armure innée 1`] = `"<div class="fe-statcard"><div class="fe-card"><div class="fe-card-head"><div class="fe-headmain"><img class="fe-portrait" alt="" src="data:image/jpeg;base64,"><h3 class="fe-card-name">Capitaine<span class="lvl">II</span></h3></div><span class="fe-cost-chip">150 Ko</span></div><div class="fe-taglist"><span class="ui-tag">Limitation U</span></div><div class="fe-stats"><div class="fe-statrow"><span class="fe-stat"><span class="k">V</span><span class="v">3</span></span><span class="fe-stat"><span class="k">P</span><span class="v">5</span></span><span class="fe-stat"><span class="k">A</span><span class="v">4</span></span><span class="fe-stat"><span class="k">C</span><span class="v">5</span></span><span class="fe-statsep" aria-hidden="true"></span><span class="fe-stat"><span class="k">T</span><span class="v">5</span></span><span class="fe-stat"><span class="k">I</span><span class="v">3</span></span></div><div class="fe-statrow fe-statrow--res"><span class="fe-stat"><span class="k">PA</span><span class="v">8</span></span><span class="fe-stat"><span class="k">PV</span><span class="v">32</span></span><span class="fe-stat"><span class="k">Stature</span><span class="v">5</span></span></div></div><div class="fe-armor" title="Armure - protection en cas d'échec / seuil / protection en cas de réussite"><span class="fe-armor-lab">🛡 Brigandine</span><span class="fe-armor-vals">0 <i>/</i> 5 <i>/</i> -2</span><span class="fe-armor-dur">durabilité 5</span></div><div class="fe-skills"><button class="fe-skill">Peau dure</button><button class="fe-skill">Autorité 2</button><button class="fe-skill">Charge brutale 1</button><button class="fe-skill">Chef de guerre 1</button><button class="fe-skill">Sadique</button></div><div class="fe-mastery"><div class="fe-dice"><span class="km-die" role="img" aria-label="Dé de maîtrise : Offensive, Défensive, Objectif"><img class="km-die-bg" alt="" src