exports[`ProfileStatCard (vue) > rend un profil avec octrois (compétence, trait, dé, limitation) de façon stable 1`] = `"<div class="fe-statcard"><div class="fe-card"><div class="fe-card-head"><div class="fe-headmain"><img class="fe-portrait" alt="" src="data:image/jpeg;base64,"><h3 class="fe-card-name">Larbin<span class="lvl">I</span></h3></div><span class="fe-cost-chip">35 Ko</span></div><div class="fe-taglist"><button class="fe-lim-fx" title="Limitation modifiée par un effet - voir la source">Limitation 6</button><span class="fe-fx-tag" title="Trait octroyé par un effet">béni</span></div><div class="fe-stats"><div class="fe-statrow"><span class="fe-stat"><span class="k">V</span><span class="v">4</span></span><span class="fe-stat"><span class="k">P</span><span class="v">3</span></span><span class="fe-stat"><span class="k">A</span><span class="v">3</span></span><span class="fe-stat"><span class="k">C</span><span class="v">3</span></span><span class="fe-statsep" aria-hidden="true"></span><span class="fe-stat"><span class="k">T</span><span class="v">2</span></span><span class="fe-stat"><span class="k">I</span><span class="v">2</span></span></div><div class="fe-statrow fe-statrow--res"><span class="fe-stat"><span class="k">PA</span><span class="v">7</span></span><span class="fe-stat"><span class="k">PV</span><span class="v">18</span></span><span class="fe-stat"><span class="k">Stature</span><span class="v">3</span></span></div></div><div class="fe-skills"><button class="fe-skill">Morsure</button><button class="fe-skill">Le sang m'attire 1</button><button class="fe-skill">Endurance</button><button class="fe-skill">Carnivore</button></div><div class="fe-rules"><div><b>Éprouvé : </b>Ne peut être recruté avec une arme.</div><div><b>Soumis : </b>+1 V et réussite automatique des tests de terreur s'il est dans l'aura du leader. Il doit défendre à la place du leader s'il est dans le même corps à corps.</div></div><div class="fe-mastery"><div class="fe-dice"><span class="km-di